# Copy this file to .env for local development (.env is gitignored, never committed).
#
# These are Supabase's project URL and anon/publishable key -- safe to
# have real values here even in a committed .example file, since the
# anon key is designed by Supabase to be public (it's already visible
# in the deployed app's JS bundle to anyone who opens devtools). Access
# control is enforced by Row Level Security policies in the database,
# not by keeping this key secret.
#
# For production (Vercel), add these same two variables under
# Project Settings -> Environment Variables, then redeploy. Until
# they're set there, the app falls back to the same values baked into
# src/lib/constants.js, so nothing breaks either way.

REACT_APP_SUPABASE_URL=https://ukoccobbjeomjwjcvrma.supabase.co
REACT_APP_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVrb2Njb2JiamVvbWp3amN2cm1hIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODExMjg4MzAsImV4cCI6MjA5NjcwNDgzMH0.a-nDh04ujZQ8w9lwu9rkHuge9xGRbLRfV7vD3zRCAqg
